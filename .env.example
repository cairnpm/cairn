# Copy to .env and fill in. Never commit your real .env.

# Required — seals login cookies (≥ 32 chars). Generate one:
#   openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# Optional — intake agent. Can also be set later in Settings → Intelligence.
ANTHROPIC_API_KEY=

# Optional overrides (sane defaults shown)
# NUXT_DB_URL=file:/data/app.db
# PORT=3000
